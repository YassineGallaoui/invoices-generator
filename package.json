{
  "name": "nuxt-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generic Nuxt 4 boilerplate, with grid system and custom routing",
  "packageManager": "pnpm@10.1.0",
  "engines": {
    "node": ">=20.18"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "start": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,vue,js,mjs,cjs,json,md,scss,css}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,js,mjs,cjs,json,md,scss,css}\"",
    "prepare": "[ -d .git ] && husky || true",
    "deps:check": "ncu",
    "deps:update": "ncu -i",
    "deps:update:minor": "ncu -u --target minor",
    "deps:update:patch": "ncu -u --target patch"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/seo": "^5.1.3",
    "motion-v": "^2.2.1",
    "msccss": "^1.0.6",
    "nuxt": "^4.4.2",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "yg-vanilla-js-helpers": "^1.2.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "npm-check-updates": "^19.0.0",
    "prettier": "^3.7.0",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.7.0",
    "vue-tsc": "^3.2.0"
  }
}
