{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm dev)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build)",
      "Bash(pnpm build:*)",
      "Bash(pnpm generate)",
      "Bash(pnpm start)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format)",
      "Bash(pnpm format:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm deps:check)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm audit)",
      "Bash(pnpm audit:*)",
      "Bash(pnpm why:*)",
      "Bash(pnpm ls:*)",
      "Bash(pnpm run:*)",
      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(git stash list)",
      "Bash(curl -s https://registry.npmjs.org/*)",
      "WebFetch(domain:nuxt.com)",
      "WebFetch(domain:vuejs.org)",
      "WebFetch(domain:motion.dev)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:web.dev)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:www.w3.org)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(npm install:*)",
      "Bash(npm i *)",
      "Bash(yarn*)",
      "Bash(bun install*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf '\\033[1;36m%s\\033[0m | \\033[1;35mNuxt4\\033[0m | \\033[32m%s\\033[0m' \"$(basename \"$PWD\")\" \"$(node --version 2>/dev/null || echo node?)\""
  }
}
